{
  "name": "@raulsaavedra/cli-core",
  "version": "0.2.0",
  "description": "Shared utilities for Raul's CLI tools (Bun/TypeScript).",
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./pkg/args": "./pkg/args/index.ts",
    "./pkg/format": "./pkg/format/index.ts",
    "./pkg/jsoninput": "./pkg/jsoninput/index.ts",
    "./pkg/output": "./pkg/output/index.ts",
    "./pkg/skills": "./pkg/skills/index.ts",
    "./pkg/sqliteutil": "./pkg/sqliteutil/index.ts",
    "./pkg/stdio": "./pkg/stdio/index.ts"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx @biomejs/biome check .",
    "format": "bunx @biomejs/biome check --write .",
    "check": "bun run lint && bun run typecheck && bun test"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.13.10",
    "bun-types": "latest",
    "typescript": "^5.8.2"
  }
}
